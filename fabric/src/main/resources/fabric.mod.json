{
  "schemaVersion": 1,
  "id": "vrmmod",
  "version": "${version}",
  "name": "VRM Mod",
  "description": "VRM avatar mod for Minecraft",
  "authors": [
    "Narazaka"
  ],
  "contact": {},
  "license": "MIT",
  "icon": "",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "com.github.narazaka.vrmmod.fabric.VrmModFabric"
      }
    ],
    "modmenu": [
      {
        "adapter": "kotlin",
        "value": "com.github.narazaka.vrmmod.fabric.VrmModMenuIntegration"
      }
    ]
  },
  "mixins": [
    "vrmmod.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "fabric-language-kotlin": ">=1.13.0+kotlin.2.1.0",
    "minecraft": "~1.21.4",
    "architectury": ">=15.0.0"
  },
  "suggests": {
    "modmenu": "*"
  }
}
