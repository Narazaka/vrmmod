{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "${description}",
  "authors": [
    "Narazaka"
  ],
  "contact": {},
  "license": "MIT",
  "icon": "",
  "environment": "*",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "net.narazaka.vrmmod.platform.VrmModFabric"
      }
    ],
    "modmenu": [
      {
        "adapter": "kotlin",
        "value": "net.narazaka.vrmmod.platform.VrmModMenuIntegration"
      }
    ]
  },
  "accessWidener": "vrmmod.accesswidener",
  "mixins": [
    "vrmmod.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "fabric-api": "*",
    "fabric-language-kotlin": "*",
    "minecraft": "~${minecraftVersion}",
    "architectury": ">=${architecturyVersion}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
